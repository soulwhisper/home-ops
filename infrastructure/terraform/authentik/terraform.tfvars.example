# Copy to terraform.tfvars (git-ignored) and fill in your values.
# The authentik API token is NOT set here; it comes from AUTHENTIK_TOKEN
# (populated by `source scripts/setup-env.sh`).

# ---------------------------------------------------------------------------
# authentik
# ---------------------------------------------------------------------------
authentik_url = "https://auth.example.com"

# ---------------------------------------------------------------------------
# 1Password
# ---------------------------------------------------------------------------
op_account    = "myteam.1password.com"
op_vault      = "myvault"
op_item_title = "authentik"
