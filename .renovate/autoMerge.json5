{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  packageRules: [
    {
      description: "Auto merge digests",
      matchUpdateTypes: ["digest"],
      automerge: true,
      automergeType: "pr",
      platformAutomerge: true,
      ignoreTests: false,
    },
    {
      description: "Auto-merge patch updates after CI",
      matchUpdateTypes: ["patch"],
      automerge: true,
      automergeType: "pr",
      platformAutomerge: true,
      ignoreTests: false,
    },
    {
      description: "User apps: auto-merge minor updates after CI",
      matchFileNames: [
        "kubernetes/apps/selfhosted-apps/**",
        "kubernetes/apps/media-apps/**",
      ],
      matchUpdateTypes: ["minor"],
      automerge: true,
      automergeType: "pr",
      platformAutomerge: true,
      ignoreTests: false,
    },
    {
      description: "Infra apps: minor require manual merge",
      matchFileNames: [
        "kubernetes/apps/kube-system/**",
        "kubernetes/apps/gitops-system/**",
        "kubernetes/apps/security-system/**",
        "kubernetes/apps/database-system/**",
        "kubernetes/apps/storage-system/**",
        "kubernetes/apps/networking-system/**",
        "kubernetes/apps/monitoring-system/**",
        "infrastructure/**",
        "kubernetes/bootstrap/**",
      ],
      matchUpdateTypes: ["minor"],
      automerge: false,
      addLabels: ["review/required"],
    },
    {
      description: "Global: major updates always require manual merge",
      matchUpdateTypes: ["major"],
      automerge: false,
      addLabels: ["review/required"],
    },
    {
      description: "Auto-merge GitHub Actions updates after CI",
      matchManagers: ["github-actions"],
      automerge: true,
      automergeType: "pr",
      platformAutomerge: true,
      matchUpdateTypes: ["minor", "patch", "digest"],
      ignoreTests: false,
    },
  ],
}
